# ==============================================================================
# 1. 补全系统防抢跑处理 (解决 Warning)
# ==============================================================================
# 彻底清理系统级 /etc/zshrc 抢跑留下的补全变量，但不注销 compinit
unset _comps
# 告诉 Zim 补全已经处理过
skip_global_compinit=1
zstyle ':zim:completion' dump_file "${ZDOTDIR:-${HOME}}/.zcompdump"

# ==============================================================================
# 2. 基础环境加载
# ==============================================================================
[[ -f ~/.zsh.d/env.zsh ]] && source ~/.zsh.d/env.zsh

# ==============================================================================
# 3. Zim 框架初始化
# ==============================================================================
ZIM_HOME=${ZDOTDIR:-${HOME}}/.zim
[[ -f ${ZIM_HOME}/init.zsh ]] && source ${ZIM_HOME}/init.zsh

# ==============================================================================
# 4. FZF 深度集成 (必须在 Zim 之后)
# ==============================================================================
if command -v fzf >/dev/null; then
    source <(fzf --zsh) 2>/dev/null
    zstyle ':fzf-tab:*' fzf-command fzf
    zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color=always $realpath'
fi

# ==============================================================================
# 5. 加载自定义工具
# ==============================================================================
ZSH_DOT_DIR="$HOME/.zsh.d"
if [[ -d "$ZSH_DOT_DIR" ]]; then
    local tool_files=("alias.zsh" "plugin.zsh" "tools/path_alias.zsh" "secrets.zsh")
    for tool in "${tool_files[@]}"; do
        [[ -f "$ZSH_DOT_DIR/$tool" ]] && source "$ZSH_DOT_DIR/$tool"
    done
fi

# ==============================================================================
# 6. 交互式设置 (键位与 Logo)
# ==============================================================================
bindkey -v
bindkey '^?' backward-delete-char

# ==============================================================================
# 7. zfm 快捷键 (必须在 bindkey -v 之后)
# ==============================================================================
bindkey -M viins '^B' zfm-cd-to-bookmark
bindkey -M viins '^O' zfm-insert-bookmark


# ==============================================================================
# 8. Kitty matplotlib 内联显示
# ==============================================================================
if [[ -n "$KITTY_WINDOW_ID" ]]; then
    export MPLBACKEND="module://matplotlib-backend-kitty"
fi

# ==============================================================================
# 9. Starship 提示符
# ==============================================================================
eval "$(starship init zsh)"

# ==============================================================================
# 10. fastfetch启动界面 (仅在 Linux 原生终端)
# ==============================================================================
if [[ "$(uname)" == "Linux" ]] \
    && [[ -z "$SSH_TTY" ]] \
    && [[ -z "$SSH_CLIENT" ]] \
    && [[ "$TERM_PROGRAM" != "vscode" ]] \
    && [[ -z "$VSCODE_INJECTION" ]] \
    && [[ "$TERMINAL_EMULATOR" != "JetBrains-JediTerm" ]] \
    && [[ -z "$TMUX" ]]; then
    fastfetch
fi

